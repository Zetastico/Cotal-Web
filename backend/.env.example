# Puerto en el que corre el servidor Express
PORT=3000

# URL de conexión a PostgreSQL (usada por Prisma)
# Reemplaza usuario, contraseña, host, puerto y nombre de base de datos según tu PostgreSQL local
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/cotal_db?schema=public"

# Clave secreta para firmar los tokens JWT
JWT_SECRET="tu_secreto_super_seguro_de_jwt"
